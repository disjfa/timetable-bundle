{% extends "@DisjfaTimetable/base.html.twig" %}

{% block _disjfa_timetable_content %}

    {% include '@DisjfaTimetable/timetable/_style.html.twig' %}

    <div class="container py-4">
        {% include '@DisjfaTimetable/timetable/_menu.html.twig' %}

        <h3>{{ timetable.title }}</h3>
        Place:
        <strong>{{ item.place.title }}</strong>
        -
        Date:
        <strong>{{ item.date.dateAt | date }}</strong>
        <hr>

        {{ form_start(form) }}

        <div class="row">
            <div class="col-12 col-md-8">
                {{ form_row(form.title) }}
                {{ form_row(form.intro) }}
                {{ form_row(form.description) }}
                <button type="submit" class="btn btn-primary">save</button>
            </div>
            <div class="col-12 col-md-4">
                {{ form_rest(form) }}
                <button type="submit" class="btn btn-primary">save</button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}

